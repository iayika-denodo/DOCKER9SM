             ADD results.cover NOS ZERO ()
             ADD results.icon NOS ZERO ()
             ADD results.parent NOS ZERO ()
             ADD results.parent.type NOS ZERO ()
             ADD results.parent.database_id NOS ZERO ()
             ADD results.in_trash NOS ZERO ()
             ADD results.is_locked NOS ZERO ()
             ADD results.properties NOS ZERO ()
             ADD results.properties.linkeditems_0 NOS ZERO ()
             ADD results.properties.linkeditems_0.id NOS ZERO ()
             ADD results.properties.linkeditems_0.type NOS ZERO ()
             ADD results.properties.linkeditems_0.relation NOS ZERO ()
             ADD results.properties.linkeditems_0.relation NOS ZERO ()
