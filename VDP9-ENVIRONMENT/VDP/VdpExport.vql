DROP VIEW IF EXISTS bv_notion CASCADE;

CREATE TABLE bv_notion I18N us_pst (
        object:text,
        results:ds_notion_results,
        next_cursor:text,
        has_more:text,
        type:text,
        page_or_database:ds_notion_page_or_database,
        request_id:text
    )
    FOLDER = '/connectivity/base views'
    CACHE OFF
    TIMETOLIVEINCACHE DEFAULT
    ADD SEARCHMETHOD ds_notion(
        I18N us_pst
        CONSTRAINTS (
             ADD object NOS ZERO ()
             ADD results NOS ZERO ()
             ADD results NOS ZERO ()
             ADD results.object NOS ZERO ()
             ADD results.id NOS ZERO ()
             ADD results.created_time NOS ZERO ()
             ADD results.last_edited_time NOS ZERO ()
             ADD results.created_by NOS ZERO ()
