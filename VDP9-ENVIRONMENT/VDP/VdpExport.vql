             ADD results.properties.assignee NOS ZERO ()
             ADD results.properties.assignee.id NOS ZERO ()
             ADD results.properties.assignee.type NOS ZERO ()
             ADD results.properties.assignee.people NOS ZERO ()
             ADD results.properties.assignee.people NOS ZERO ()
             ADD results.properties.assignee.people.field_0 NOS ZERO ()
             ADD results.properties.linkednotes_0 NOS ZERO ()
             ADD results.properties.linkednotes_0.id NOS ZERO ()
