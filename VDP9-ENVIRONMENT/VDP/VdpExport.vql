             ADD results.properties.location.type NOS ZERO ()
             ADD results.properties.location.rich_text NOS ZERO ()
             ADD results.properties.location.rich_text NOS ZERO ()
             ADD results.properties.location.rich_text.field_0 NOS ZERO ()
             ADD results.properties.extrainfo_0 NOS ZERO ()
