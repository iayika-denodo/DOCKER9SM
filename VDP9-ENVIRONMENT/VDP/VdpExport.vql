             ADD results.properties.relatedtasks_0.relation NOS ZERO ()
             ADD results.properties.relatedtasks_0.relation NOS ZERO ()
             ADD results.properties.relatedtasks_0.relation.field_0 NOS ZERO ()
             ADD results.properties.relatedtasks_0.has_more NOS ZERO ()
             ADD results.properties.location NOS ZERO ()
