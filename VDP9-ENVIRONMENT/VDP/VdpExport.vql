             ADD page_or_database NOS ZERO ()
             ADD page_or_database.field_0 NOS ZERO ()
             ADD request_id NOS ZERO ()
        )
        OUTPUTLIST (has_more, next_cursor, object, page_or_database, request_id, results, type
        )
        WRAPPER (json ds_notion)
    );

CHOWN admin VIEW bv_notion LASTMODIFICATIONUSER "admin (smtoken)";

# #######################################
# VIEWS of http
# #######################################
DROP VIEW IF EXISTS iv_notion CASCADE;

CREATE VIEW iv_notion FOLDER = '/intergration' AS SELECT bv_notion.object AS object, bv_notion.results AS results, bv_notion.next_cursor AS next_cursor, bv_notion.has_more AS has_more, bv_notion.type AS type, bv_notion.page_or_database AS page_or_database, bv_notion.request_id AS request_id FROM bv_notion;

CHOWN admin VIEW iv_notion LASTMODIFICATIONUSER "admin (smtoken)";

ALTER VIEW iv_notion
 LAYOUT (bv_notion = [20, 20, 200, 200]);

